# Server Configuration
PORT=5001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://czlehwhhehplkaprbqcm.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Transcription Provider Configuration
# Options: linux_ssh (development), openai_api (production)
TRANSCRIPTION_PROVIDER=linux_ssh

# Linux SSH Whisper Configuration (for dev)
# SSH alias from ~/.ssh/config — this is how we reach the Linux box
WHISPER_SSH_TARGET=linuxbox

# Path to the Whisper virtual environment on the Linux box
WHISPER_REMOTE_VENV_PATH=/home/blueweb/whisper-env

# OpenAI Whisper API Configuration (for future production use — not active yet)
# OPENAI_API_KEY=your_openai_api_key_here
