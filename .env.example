# ── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Where the frontend lives. Used by the QuickBooks OAuth callback to redirect
# back into the app after Intuit finishes.
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed CORS origins. If unset, all origins are allowed
# (only acceptable for local dev). Example:
#   CORS_ORIGIN=https://myapp.netlify.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://czlehwhhehplkaprbqcm.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service-role key bypasses RLS — used to verify JWTs and to read/write the
# quickbooks_connections table. NEVER expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Transcription provider ───────────────────────────────────────────────────
# Options:
#   openai_whisper  — OpenAI Whisper API (DEFAULT, works on Railway)
#   linux_ssh       — remote Whisper over SSH (local dev only)
#   none / disabled — audio transcription off; use /api/parse-transcript
TRANSCRIPTION_PROVIDER=openai_whisper

# Required when TRANSCRIPTION_PROVIDER=openai_whisper
OPENAI_API_KEY=your_openai_api_key_here

# Required when TRANSCRIPTION_PROVIDER=linux_ssh (local dev only)
# WHISPER_SSH_TARGET=linuxbox
# WHISPER_REMOTE_VENV_PATH=/home/blueweb/whisper-env

# ── Claude API (invoice parsing) ─────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── QuickBooks Online ────────────────────────────────────────────────────────
# Get from: https://developer.intuit.com → Your App → Keys & OAuth
# Tokens are stored per-user in the quickbooks_connections Supabase table —
# you do NOT set QBO_ACCESS_TOKEN or QBO_REALM_ID here anymore.
INTUIT_CLIENT_ID=your_client_id
INTUIT_CLIENT_SECRET=your_client_secret
INTUIT_REDIRECT_URI=http://localhost:5001/api/quickbooks/callback
INTUIT_ENVIRONMENT=sandbox
