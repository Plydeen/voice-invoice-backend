# Server Configuration
PORT=5001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://czlehwhhehplkaprbqcm.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Transcription Provider Configuration
# Options:
#   none / disabled  — audio transcription off; use /api/parse-transcript for the demo (DEFAULT / Railway)
#   linux_ssh        — remote Whisper over SSH; local development only, requires SSH key + Linux box
# Future (not yet implemented):
#   openai_whisper   — OpenAI Whisper API (cloud-safe)
TRANSCRIPTION_PROVIDER=none

# Linux SSH Whisper Configuration (local dev only — not used on Railway)
# Only needed when TRANSCRIPTION_PROVIDER=linux_ssh
# WHISPER_SSH_TARGET=linuxbox
# WHISPER_REMOTE_VENV_PATH=/home/blueweb/whisper-env

# Claude API Configuration (Stage 3 — invoice parsing)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI Whisper API Configuration (for future production use — not active yet)
# OPENAI_API_KEY=your_openai_api_key_here

# ── Demo / Testing ────────────────────────────────────────────────────────────
# Set MOCK_INVOICE_PARSE=true to bypass Claude API and return hardcoded invoice data.
# Use this only if ANTHROPIC_API_KEY is expired or unavailable during a demo.
# MOCK_INVOICE_PARSE=true

# ── QuickBooks Online (Stage 4) ───────────────────────────────────────────────
# Get from: https://developer.intuit.com → Your App → Keys & OAuth
# INTUIT_CLIENT_ID=your_client_id
# INTUIT_CLIENT_SECRET=your_client_secret
# INTUIT_REDIRECT_URI=http://localhost:5001/api/quickbooks/callback
# INTUIT_ENVIRONMENT=sandbox
# QBO_REALM_ID=        ← populated after OAuth flow
# QBO_ACCESS_TOKEN=    ← populated after OAuth flow
# QBO_REFRESH_TOKEN=   ← populated after OAuth flow
